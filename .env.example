# Copy to .env (gitignored) and fill in real values. NEVER put real secrets here.

# ---- Database (Supabase Postgres) ----
# Use the Supabase connection string (Session pooler / port 5432 or 6543). NOT Supabase S3.
DATABASE_URI=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# ---- Payload ----
# Generate with: openssl rand -hex 32
PAYLOAD_SECRET=replace-with-a-long-random-string

# ---- Public site URL (used for SEO/canonical + Payload serverURL) ----
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ---- Media host: Phase 1 = Vercel Blob (later swap to Cloudflare R2) ----
# Vercel Blob:
BLOB_READ_WRITE_TOKEN=
# Cloudflare R2 (fill when migrating; see src/payload/payload.config.ts storage block):
# R2_BUCKET=
# R2_ENDPOINT=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=

# ---- Supabase (client SDK — optional, not used by Payload itself) ----
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT].supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
